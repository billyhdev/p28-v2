{
  "$meta": {
    "format": "design-tokens",
    "version": "1.0.0",
    "usageNote": "Import into theme/tokens.ts. All numeric values are dp/sp (React Native). All colors are hex or rgba strings."
  },

  "color": {
    "ink900":           { "$value": "#1F2130", "$type": "color" },
    "ink700":           { "$value": "#4D5060", "$type": "color" },
    "ink500":           { "$value": "#7D8193", "$type": "color" },
    "ink300":           { "$value": "#B8BDCB", "$type": "color" },
    "surface0":         { "$value": "#FFFFFF",  "$type": "color" },
    "surface50":        { "$value": "#F8F9FC",  "$type": "color" },
    "surface100":       { "$value": "#F1F3F8",  "$type": "color" },
    "surfaceTint":      { "$value": "#EEF1F8",  "$type": "color" },

    "brandPrimary":     { "$value": "#4B3A8A",  "$type": "color" },
    "brandPrimaryDark": { "$value": "#3F2E80",  "$type": "color" },
    "brandLight":       { "$value": "#8F7CD8",  "$type": "color" },
    "brandSoft":        { "$value": "#E9E2FF",  "$type": "color" },

    "blue":             { "$value": "#6AAEE6",  "$type": "color" },
    "blueSoft":         { "$value": "#DCEEFF",  "$type": "color" },
    "coral":            { "$value": "#EA8E78",  "$type": "color" },
    "coralSoft":        { "$value": "#FBE3DC",  "$type": "color" },
    "lavender":         { "$value": "#A286F3",  "$type": "color" },
    "lavenderSoft":     { "$value": "#EDE6FF",  "$type": "color" },
    "peach":            { "$value": "#F2B5A1",  "$type": "color" },
    "greenSoft":        { "$value": "#DDF4E8",  "$type": "color" },
    "amberSoft":        { "$value": "#FFF2CF",  "$type": "color" },

    "success":          { "$value": "#3AA76D",  "$type": "color" },
    "warning":          { "$value": "#D08B34",  "$type": "color" },
    "danger":           { "$value": "#D95858",  "$type": "color" },
    "info":             { "$value": "#4D8FD9",  "$type": "color" },

    "cardDefault":      { "$value": "#F4F7FD",  "$type": "color" },
    "cardAlt":          { "$value": "#FCE9E6",  "$type": "color" },
    "cardHighlight":    { "$value": "#E9F1FF",  "$type": "color" },

    "borderSubtle":     { "$value": "rgba(30, 27, 45, 0.08)", "$type": "color" },
    "focusRing":        { "$value": "rgba(75, 58, 138, 0.35)", "$type": "color" }
  },

  "gradient": {
    "screenBackground": {
      "$value": {
        "type": "linear",
        "angle": 145,
        "stops": ["#F1ECFF", "#EFF3FA"]
      },
      "$type": "gradient",
      "$note": "Use experimental_backgroundImage in React Native: 'linear-gradient(145deg, #F1ECFF, #EFF3FA)'"
    }
  },

  "spacing": {
    "xxs":  { "$value": 4,  "$type": "dimension" },
    "xs":   { "$value": 8,  "$type": "dimension" },
    "sm":   { "$value": 12, "$type": "dimension" },
    "md":   { "$value": 16, "$type": "dimension" },
    "lg":   { "$value": 20, "$type": "dimension" },
    "xl":   { "$value": 24, "$type": "dimension" },
    "2xl":  { "$value": 32, "$type": "dimension" },
    "3xl":  { "$value": 40, "$type": "dimension" }
  },

  "radius": {
    "sm":   { "$value": 10,  "$type": "dimension" },
    "md":   { "$value": 14,  "$type": "dimension" },
    "lg":   { "$value": 18,  "$type": "dimension" },
    "xl":   { "$value": 24,  "$type": "dimension" },
    "pill": { "$value": 999, "$type": "dimension" }
  },

  "size": {
    "iconXs":         { "$value": 14, "$type": "dimension" },
    "iconSm":         { "$value": 16, "$type": "dimension" },
    "iconMd":         { "$value": 20, "$type": "dimension" },
    "iconLg":         { "$value": 24, "$type": "dimension" },
    "avatarSm":       { "$value": 22, "$type": "dimension" },
    "avatarMd":       { "$value": 28, "$type": "dimension" },
    "avatarLg":       { "$value": 34, "$type": "dimension" },
    "avatarOverlap":  { "$value": 8,  "$type": "dimension" },
    "chipHeight":     { "$value": 28, "$type": "dimension" },
    "buttonHeight":   { "$value": 44, "$type": "dimension" },
    "buttonHeightLg": { "$value": 46, "$type": "dimension" },
    "inputHeight":    { "$value": 48, "$type": "dimension" },
    "listItemMin":    { "$value": 56, "$type": "dimension" },
    "fabDiameter":    { "$value": 56, "$type": "dimension" },
    "iconButtonSize": { "$value": 36, "$type": "dimension" },
    "tabBarHeight":   { "$value": 74, "$type": "dimension" },
    "checkboxSize":   { "$value": 20, "$type": "dimension" },
    "outerMargin":    { "$value": 20, "$type": "dimension" },
    "touchTargetMin": { "$value": 44, "$type": "dimension" }
  },

  "typography": {
    "fontFamilyPrimary": { "$value": "Inter",     "$type": "fontFamily" },
    "fontFamilySystem":  { "$value": "System",    "$type": "fontFamily" },

    "weightRegular":  { "$value": "400", "$type": "fontWeight" },
    "weightMedium":   { "$value": "500", "$type": "fontWeight" },
    "weightSemibold": { "$value": "600", "$type": "fontWeight" },
    "weightBold":     { "$value": "700", "$type": "fontWeight" },

    "trackingDefault":   { "$value": 0,    "$type": "number" },
    "trackingTight":     { "$value": -0.2, "$type": "number" },
    "trackingCapsLabel": { "$value": 0.3,  "$type": "number" },

    "display":    { "$value": { "fontSize": 42, "lineHeight": 48, "fontWeight": "700" }, "$type": "typography" },
    "h1":         { "$value": { "fontSize": 40, "lineHeight": 46, "fontWeight": "700" }, "$type": "typography" },
    "h2":         { "$value": { "fontSize": 28, "lineHeight": 34, "fontWeight": "600" }, "$type": "typography" },
    "h3":         { "$value": { "fontSize": 22, "lineHeight": 28, "fontWeight": "600" }, "$type": "typography" },
    "title":      { "$value": { "fontSize": 18, "lineHeight": 24, "fontWeight": "600" }, "$type": "typography" },
    "body":       { "$value": { "fontSize": 15, "lineHeight": 22, "fontWeight": "400" }, "$type": "typography" },
    "bodyStrong": { "$value": { "fontSize": 15, "lineHeight": 22, "fontWeight": "600" }, "$type": "typography" },
    "caption":    { "$value": { "fontSize": 13, "lineHeight": 18, "fontWeight": "500" }, "$type": "typography" },
    "micro":      { "$value": { "fontSize": 11, "lineHeight": 14, "fontWeight": "500" }, "$type": "typography" }
  },

  "shadow": {
    "none": {
      "$value": {
        "shadowColor": "transparent",
        "shadowOpacity": 0,
        "shadowRadius": 0,
        "shadowOffset": { "width": 0, "height": 0 },
        "elevation": 0
      },
      "$type": "shadow"
    },
    "cardSoft": {
      "$value": {
        "shadowColor": "#1A1530",
        "shadowOpacity": 0.06,
        "shadowRadius": 18,
        "shadowOffset": { "width": 0, "height": 6 },
        "elevation": 2
      },
      "$type": "shadow"
    },
    "floating": {
      "$value": {
        "shadowColor": "#1A1530",
        "shadowOpacity": 0.14,
        "shadowRadius": 22,
        "shadowOffset": { "width": 0, "height": 10 },
        "elevation": 6
      },
      "$type": "shadow"
    }
  },

  "motion": {
    "durationPress":      { "$value": 120, "$type": "duration" },
    "durationStandard":   { "$value": 220, "$type": "duration" },
    "durationSnappy":     { "$value": 160, "$type": "duration" },
    "easingStandard":     { "$value": "ease-out",    "$type": "cubicBezier" },
    "easingSnappy":       { "$value": "ease-in-out", "$type": "cubicBezier" },
    "pressScale":         { "$value": 0.98, "$type": "number" },
    "pressOpacity":       { "$value": 0.92, "$type": "number" }
  },

  "semantic": {
    "textPrimary":      { "$value": "{color.ink900}",       "$type": "color" },
    "textSecondary":    { "$value": "{color.ink700}",       "$type": "color" },
    "textTertiary":     { "$value": "{color.ink500}",       "$type": "color" },
    "textDisabled":     { "$value": "{color.ink300}",       "$type": "color" },
    "textOnBrand":      { "$value": "{color.surface0}",     "$type": "color" },
    "textLink":         { "$value": "{color.brandPrimary}", "$type": "color" },

    "bgScreen":         { "$value": "{color.surface50}",   "$type": "color" },
    "bgCard":           { "$value": "{color.cardDefault}",  "$type": "color" },
    "bgCardAlt":        { "$value": "{color.cardAlt}",      "$type": "color" },
    "bgSurface":        { "$value": "{color.surface0}",     "$type": "color" },

    "iconActive":       { "$value": "{color.brandPrimary}", "$type": "color" },
    "iconDefault":      { "$value": "#A2A7B8",              "$type": "color" },

    "borderDefault":    { "$value": "{color.borderSubtle}", "$type": "color" },

    "pageMargin":       { "$value": "{spacing.lg}",         "$type": "dimension" },
    "sectionGap":       { "$value": "{spacing.xl}",         "$type": "dimension" },
    "cardPadding":      { "$value": "{spacing.md}",         "$type": "dimension" },
    "cardRadius":       { "$value": "{radius.xl}",          "$type": "dimension" },
    "cardShadow":       { "$value": "{shadow.cardSoft}",    "$type": "shadow" }
  },

  "component": {
    "tabBar": {
      "height":          { "$value": 74,        "$type": "dimension" },
      "radius":          { "$value": 22,        "$type": "dimension" },
      "bg":              { "$value": "#FFFFFF",  "$type": "color" },
      "shadow":          { "$value": "{shadow.floating}", "$type": "shadow" },
      "iconSize":        { "$value": 20,        "$type": "dimension" },
      "labelSize":       { "$value": 11,        "$type": "dimension" },
      "activeColor":     { "$value": "#4B3A8A", "$type": "color" },
      "inactiveColor":   { "$value": "#A2A7B8", "$type": "color" },
      "fabSize":         { "$value": 56,        "$type": "dimension" },
      "fabBg":           { "$value": "#3F2E80", "$type": "color" },
      "fabIcon":         { "$value": "#FFFFFF", "$type": "color" },
      "fabOffsetY":      { "$value": -18,       "$type": "number" }
    },

    "card": {
      "radius":       { "$value": 20, "$type": "dimension" },
      "padding":      { "$value": 16, "$type": "dimension" },
      "contentGap":   { "$value": 10, "$type": "dimension" },
      "shadow":       { "$value": "{shadow.cardSoft}", "$type": "shadow" }
    },

    "scheduleCard": {
      "radius":       { "$value": 14, "$type": "dimension" },
      "bgBlue":       { "$value": "#DCEEFF", "$type": "color" },
      "bgCoral":      { "$value": "#FBE3DC", "$type": "color" }
    },

    "chip": {
      "height":            { "$value": 26,        "$type": "dimension" },
      "paddingHorizontal": { "$value": 10,        "$type": "dimension" },
      "radius":            { "$value": 13,        "$type": "dimension" },
      "lowBg":             { "$value": "#FDEFEA", "$type": "color" },
      "lowText":           { "$value": "#AC6A57", "$type": "color" },
      "highBg":            { "$value": "#EEF3FF", "$type": "color" },
      "highText":          { "$value": "#4C6294", "$type": "color" }
    },

    "primaryButton": {
      "height":     { "$value": 46,        "$type": "dimension" },
      "radius":     { "$value": 14,        "$type": "dimension" },
      "bg":         { "$value": "#4B3A8A", "$type": "color" },
      "textColor":  { "$value": "#FFFFFF", "$type": "color" }
    },

    "ghostButton": {
      "height":     { "$value": 44,        "$type": "dimension" },
      "radius":     { "$value": 14,        "$type": "dimension" },
      "textColor":  { "$value": "#4B3A8A", "$type": "color" }
    },

    "iconButton": {
      "size":       { "$value": 36,        "$type": "dimension" },
      "bg":         { "$value": "#FFFFFF", "$type": "color" },
      "iconColor":  { "$value": "#2E3344", "$type": "color" },
      "shadow":     { "$value": "{shadow.cardSoft}", "$type": "shadow" }
    },

    "textInput": {
      "height":             { "$value": 48,        "$type": "dimension" },
      "radius":             { "$value": 14,        "$type": "dimension" },
      "bg":                 { "$value": "#FFFFFF",  "$type": "color" },
      "placeholder":        { "$value": "#9DA3B3", "$type": "color" },
      "paddingHorizontal":  { "$value": 14,        "$type": "dimension" },
      "focusBorderColor":   { "$value": "rgba(75, 58, 138, 0.35)", "$type": "color" }
    },

    "checkbox": {
      "size":             { "$value": 20,        "$type": "dimension" },
      "uncheckedBorder":  { "$value": "#C2C7D5", "$type": "color" },
      "checkedFill":      { "$value": "#4B3A8A", "$type": "color" },
      "checkColor":       { "$value": "#FFFFFF", "$type": "color" }
    },

    "progressDonut": {
      "track":         { "$value": "#E9ECF4", "$type": "color" },
      "seg1":          { "$value": "#A286F3", "$type": "color" },
      "seg2":          { "$value": "#EA8E78", "$type": "color" },
      "seg3":          { "$value": "#6AAEE6", "$type": "color" },
      "holeRatio":     { "$value": 0.58, "$type": "number" }
    },

    "progressBar": {
      "height":     { "$value": 6,        "$type": "dimension" },
      "radius":     { "$value": 999,      "$type": "dimension" },
      "track":      { "$value": "#D9DFEA", "$type": "color" },
      "fill":       { "$value": "#D97C69", "$type": "color" }
    },

    "calendar": {
      "bg":                 { "$value": "#FFFFFF",  "$type": "color" },
      "radius":             { "$value": 18,        "$type": "dimension" },
      "padding":            { "$value": 14,        "$type": "dimension" },
      "weekdayColor":       { "$value": "#A0A6B6", "$type": "color" },
      "dateCellSize":       { "$value": 30,        "$type": "dimension" },
      "selectedBg":         { "$value": "#D8E8FF", "$type": "color" },
      "selectedTextColor":  { "$value": "#405070", "$type": "color" },
      "defaultTextColor":   { "$value": "#353A49", "$type": "color" }
    },

    "modalSheet": {
      "topRadius":   { "$value": 24,        "$type": "dimension" },
      "bg":          { "$value": "#FFFFFF",  "$type": "color" },
      "handleWidth": { "$value": 36,        "$type": "dimension" },
      "handleHeight": { "$value": 4,        "$type": "dimension" },
      "handleColor": { "$value": "#D0D5E0", "$type": "color" }
    },

    "sectionTab": {
      "activeTextColor":   { "$value": "#2E3344", "$type": "color" },
      "activeWeight":      { "$value": "600",     "$type": "fontWeight" },
      "inactiveTextColor": { "$value": "#8A90A3", "$type": "color" }
    },

    "avatar": {
      "ringColor":  { "$value": "#FFFFFF", "$type": "color" },
      "ringWidth":  { "$value": 1.5,       "$type": "number" },
      "overlap":    { "$value": 8,         "$type": "dimension" }
    }
  }
}
