# Supabase (Story 1.3). Copy to .env and fill with your project URL and anon key.
# Do not commit .env or real keys.
# For Expo, you may use EXPO_PUBLIC_* below (or set in app.config) so the adapter can read them.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=  (required for npm run db:delete-chats)
# EXPO_PUBLIC_EAS_PROJECT_ID=  (recommended for push: UUID from `eas project:info` or app.json extra.eas.projectId)
# Note: Remote push does not work in Expo Go on Android (SDK 53+). Use a dev build to test pushes on Android.
